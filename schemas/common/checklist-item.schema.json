{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "common/checklist-item.schema.json",
  "title": "Checklist Item",
  "type": "object",
  "required": [
    "id",
    "description",
    "status",
    "blocker",
    "owner",
    "dueAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "IN_PROGRESS", "COMPLETE", "WAIVED", "FAILED"]
    },
    "blocker": {
      "type": "boolean"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "dueAt": {
      "type": "string",
      "minLength": 10
    },
    "evidencePath": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
