{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phases/legal-data.schema.json",
  "title": "Legal Downstream Data",
  "type": "object",
  "required": [
    "agentFindings",
    "psaStatus",
    "titleStatus",
    "estoppelStatus",
    "insuranceStatus",
    "transferDocStatus",
    "closingChecklistStatus",
    "riskScore",
    "redFlagCount",
    "dataGapCount"
  ],
  "properties": {
    "agentFindings": {
      "type": "object"
    },
    "psaStatus": {
      "type": "object",
      "required": ["reviewStatus"],
      "properties": {
        "reviewStatus": { "type": "string" }
      },
      "additionalProperties": true
    },
    "titleStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "estoppelStatus": {
      "type": "object",
      "required": ["returnRate"],
      "properties": {
        "returnRate": { "type": "number" }
      },
      "additionalProperties": true
    },
    "insuranceStatus": {
      "type": "object",
      "required": ["overallStatus"],
      "properties": {
        "overallStatus": { "type": "string" }
      },
      "additionalProperties": true
    },
    "loanDocStatus": {
      "type": "object"
    },
    "transferDocStatus": {
      "type": "object",
      "required": ["overallReadiness"],
      "properties": {
        "overallReadiness": { "type": "string" }
      },
      "additionalProperties": true
    },
    "closingChecklistStatus": {
      "type": "object"
    },
    "riskScore": {
      "type": "number"
    },
    "redFlagCount": {
      "type": "number",
      "minimum": 0
    },
    "dataGapCount": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
