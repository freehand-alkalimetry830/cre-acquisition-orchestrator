{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "checkpoint/master-checkpoint.schema.json",
  "title": "Master Deal Checkpoint",
  "type": "object",
  "required": [
    "dealId",
    "dealName",
    "status",
    "overallProgress",
    "startedAt",
    "lastUpdatedAt",
    "phases"
  ],
  "properties": {
    "dealId": {
      "type": "string",
      "minLength": 1
    },
    "dealName": {
      "type": "string",
      "minLength": 1
    },
    "property": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "RUNNING", "COMPLETE", "FAILED", "PARTIAL"]
    },
    "overallProgress": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "currentPhase": {
      "type": ["string", "null"]
    },
    "startedAt": {
      "type": "string"
    },
    "lastUpdatedAt": {
      "type": "string"
    },
    "completedAt": {
      "type": ["string", "null"]
    },
    "resumeInstructions": {
      "type": "string"
    },
    "traceId": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "seed": {
      "type": "number"
    },
    "phases": {
      "type": "object",
      "required": [
        "dueDiligence",
        "underwriting",
        "financing",
        "legal",
        "closing"
      ],
      "properties": {
        "dueDiligence": {
          "type": "object"
        },
        "underwriting": {
          "type": "object"
        },
        "financing": {
          "type": "object"
        },
        "legal": {
          "type": "object"
        },
        "closing": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
