{
  "name": "cre-acquisition-dashboard",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/watcher.ts",
    "start:client:test": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "start:server:test": "tsx server/watcher.ts",
    "build": "tsc -p tsconfig.server.json && tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "node ./scripts/run-e2e.mjs",
    "test:e2e:headed": "node ./scripts/run-e2e.mjs --headed"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
